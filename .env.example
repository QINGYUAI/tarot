# 前端环境变量
VITE_APP_TITLE=塔罗占卜
# 打包路径：./ 相对路径（Hash 路由推荐）| /tarot/ 固定子目录
VITE_BASE_PATH=./
# 打包输出目录名
VITE_OUT_DIR=tarot
VITE_AI_MODELS=[{"id":"deepseek","name":"DeepSeek","enabled":true},{"id":"zhipu","name":"智谱清言","enabled":true},{"id":"qwen","name":"通义千问","enabled":true},{"id":"xiaomi","name":"小米 MiMo","enabled":true}]
VITE_DEFAULT_MODEL=deepseek

# 后端 AI 密钥（复制为 .env 并填入真实 Key，未配置的模型将不可用）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
XIAOMI_API_KEY=your_xiaomi_api_key_here
PORT=3001

# 后端日志目录（默认项目根目录 logs/）
LOG_DIR=logs

# 日志查看页（隐藏入口，仅地址栏访问）
LOG_VIEWER_PASSWORD=qingyuai
LOG_VIEWER_PATH=/api/internal/logs/panel
